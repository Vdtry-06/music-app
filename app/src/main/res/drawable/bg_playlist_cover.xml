<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <gradient
                android:angle="315"
                android:startColor="@color/cover_pink_start"
                android:centerColor="@color/cover_pink_mid"
                android:endColor="@color/cover_pink_end" />
        </shape>
    </item>
    <item
        android:gravity="top|center_horizontal"
        android:top="16dp">
        <shape android:shape="rectangle">
            <size
                android:width="122dp"
                android:height="2dp" />
            <corners android:radius="1dp" />
            <solid android:color="#55FFFFFF" />
        </shape>
    </item>
    <item
        android:gravity="bottom|right"
        android:right="22dp"
        android:bottom="22dp">
        <shape android:shape="rectangle">
            <size
                android:width="72dp"
                android:height="72dp" />
            <corners android:radius="36dp" />
            <gradient
                android:angle="0"
                android:startColor="#10101010"
                android:endColor="#38000000" />
        </shape>
    </item>
    <item
        android:gravity="bottom|left"
        android:left="20dp"
        android:bottom="20dp">
        <shape android:shape="rectangle">
            <size
                android:width="118dp"
                android:height="132dp" />
            <corners android:radius="60dp" />
            <gradient
                android:angle="180"
                android:startColor="#3D131539"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>
