<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomBar"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvPlayingFrom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PLAYING FROM PLAYLIST:"
                android:textColor="@color/gray_text"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvPlaylistName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lofi Loft"
                android:textColor="@color/cyan"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvPlayingFrom" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_custom"
                app:layout_constraintBottom_toBottomOf="@+id/tvPlaylistName"
                app:layout_constraintStart_toEndOf="@+id/tvPlaylistName"
                app:layout_constraintTop_toTopOf="@+id/tvPlaylistName"
                app:tint="@color/cyan" />

            <TextView
                android:id="@+id/tvNowPlayingLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="now playing :"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvPlaylistName" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivNowPlayingCover"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginTop="16dp"
                android:scaleType="centerCrop"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvNowPlayingLabel"
                app:shapeAppearanceOverlay="@style/RoundedSquare"
                tools:src="@tools:sample/avatars" />

            <TextView
                android:id="@+id/tvNowPlayingTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="grainy days"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@+id/tvNowPlayingArtist"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/ivNowPlayingCover"
                app:layout_constraintTop_toTopOf="@+id/ivNowPlayingCover"
                app:layout_constraintVertical_chainStyle="packed" />

            <TextView
                android:id="@+id/tvNowPlayingArtist"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="moody."
                android:textColor="@color/gray_text"
                android:textSize="14sp"
                app:layout_constraintBottom_toBottomOf="@+id/ivNowPlayingCover"
                app:layout_constraintEnd_toEndOf="@+id/tvNowPlayingTitle"
                app:layout_constraintStart_toStartOf="@+id/tvNowPlayingTitle"
                app:layout_constraintTop_toBottomOf="@+id/tvNowPlayingTitle" />

            <TextView
                android:id="@+id/tvNextInQueueLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:text="next in queue :"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/ivNowPlayingCover" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClearQueue"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CLEAR QUEUE"
                android:textColor="@color/cyan"
                android:textSize="10sp"
                app:cornerRadius="20dp"
                app:layout_constraintBottom_toBottomOf="@+id/tvNextInQueueLabel"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/tvNextInQueueLabel"
                app:strokeColor="@color/cyan" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvNextInQueue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvNextInQueueLabel"
                tools:itemCount="3"
                tools:listitem="@layout/item_song_queue" />

            <TextView
                android:id="@+id/tvNextInPlaylistLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="next in 'playlist' :"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/rvNextInQueue" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvNextInPlaylist"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvNextInPlaylistLabel"
                tools:itemCount="5"
                tools:listitem="@layout/item_song_queue" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#121212"
        android:paddingHorizontal="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:visibility="visible">

        <TextView
            android:id="@+id/btnRemove"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="REMOVE"
            android:textColor="@color/cyan"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/btnAddToQueue"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="ADD TO QUEUE"
            android:textColor="@color/cyan"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>